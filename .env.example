# Template for environment variables.
# For production/local development, create a copy called `.env.local` 
# and fill in the actual values. DO NOT commit `.env.local` to git.

# API endpoints
VITE_API_BASE_URL=https://your-api-domain.com/v1

# Contact Form Service (e.g., EmailJS, Web3Forms, etc.)
VITE_CONTACT_SERVICE_ID=your_service_id
VITE_CONTACT_TEMPLATE_ID=your_template_id
VITE_CONTACT_PUBLIC_KEY=your_public_key
